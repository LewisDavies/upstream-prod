# Copy this file to .env and fill in credentials for the platform(s) you have access to.
# You only need to populate the section for the platform you intend to test against.

# ── Snowflake (UP_TARGET_PLATFORM=sf) ────────────────────────────────────────────────────
UP_SF_ACCOUNT=
UP_SF_USER=
UP_SF_ROLE=
UP_SF_PRIVATE_KEY_PATH=
UP_SF_WAREHOUSE=

# ── Databricks (UP_TARGET_PLATFORM=dbx) ─────────────────────────────────────────────────
UP_DBX_HOST=
UP_DBX_TOKEN=
UP_DBX_HTTP_PATH=

# ── BigQuery (UP_TARGET_PLATFORM=bq) ────────────────────────────────────────────────────
UP_BQ_KEYFILE=
